# ScholarSwarm AI: Environment Configuration Template
# Copy this file to '.env' and fill in your credentials.

# Google Gemini API configuration
# Generate your API key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama server configuration (optional, for local execution fallback)
# Default port for Ollama is 11434
OLLAMA_HOST=http://localhost:11434

# Primary LLM provider selection: 'ollama', 'gemini', or 'hybrid'
MODEL_PROVIDER=ollama
